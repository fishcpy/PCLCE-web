    "*.{ts,mts,vue,js,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@mdit/plugin-figure": "^0.23.1",
    "@theojs/lumen": "^6.4.5",
    "@types/node": "^25.5.0",
    "colorthief": "^3.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vitepress": "2.0.0-alpha.17"
  }
}
